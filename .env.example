# AI Development Stack Configuration
# Copy this file to .env and customize as needed

# Security Keys (Generate with: openssl rand -hex 32)
WEBUI_SECRET_KEY=your-secret-key-here
SEARXNG_SECRET=your-searxng-secret-here

# OpenWork Authentication (Generate with: openssl rand -hex 32)
OPENWORK_TOKEN=your-openwork-access-token-here
OPENWORK_HOST_TOKEN=your-openwork-host-token-here

# Service Ports
OPENWEBUI_PORT=3001
SEARXNG_PORT=8081
REDIS_PORT=6380
OLLAMA_PORT=11434
OPENWORK_PORT=8787

# Ollama Configuration
OLLAMA_HOST=127.0.0.1:11434
OLLAMA_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
OLLAMA_MODELS_PATH=/home/daniel/.ollama/models
OLLAMA_KEEP_ALIVE=24h
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=2
OLLAMA_FLASH_ATTENTION=1

# Performance Tuning
COMPOSE_PARALLEL_LIMIT=10
DOCKER_CLIENT_TIMEOUT=300

# Monitoring (Optional)
ENABLE_MONITORING=false
PROMETHEUS_PORT=9090
GRAFANA_PORT=3002

# Development Mode
DEBUG_MODE=false
LOG_LEVEL=INFO

# User Configuration
USER_NAME=daniel
USER_HOME=/home/daniel