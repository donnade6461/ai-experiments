{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "default",
  "scroll_speed": 3,
  "scroll_acceleration": {
    "enabled": true
  },
  "diff_style": "auto",
  "compact_mode": false,
  "keybinds": {
    "tab": "switch_agent",
    "ctrl+c": "interrupt",
    "escape": "cancel",
    "enter": "submit"
  }
}