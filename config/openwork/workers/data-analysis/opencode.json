{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "type": "ollama",
    "url": "http://ollama:11434",
    "model": "llama3.1:8b"
  },
  "fallback_providers": [
    {
      "type": "ollama",
      "url": "http://ollama:11434", 
      "model": "qwen2.5-coder:14b"
    }
  ],
  "features": {
    "data_analysis": true,
    "file_operations": true,
    "web_search": true,
    "visualization": true,
    "statistical_analysis": true
  },
  "workspace": {
    "root": "/workspace/workers/data-analysis",
    "auto_save": true,
    "backup_enabled": true
  },
  "skills": [
    "pandas-analysis",
    "numpy-computation",
    "matplotlib-visualization",
    "seaborn-plotting",
    "statistical-modeling",
    "data-cleaning",
    "csv-processing",
    "json-analysis",
    "database-queries",
    "report-generation"
  ],
  "automations": {
    "data_validation": {
      "enabled": true,
      "auto_run": true,
      "checks": ["missing_values", "data_types", "outliers"]
    },
    "visualization": {
      "enabled": true,
      "auto_run": false,
      "default_format": "png",
      "themes": ["seaborn", "matplotlib"]
    },
    "reporting": {
      "enabled": true,
      "auto_run": false,
      "formats": ["html", "pdf", "markdown"]
    }
  }
}