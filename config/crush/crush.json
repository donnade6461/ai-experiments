{
  "$schema": "https://charm.land/crush.json",
  "providers": {
    "ollama-coding": {
      "name": "Local Ollama Coding",
      "base_url": "http://localhost:11434/v1/",
      "type": "openai-compat",
      "models": [
        {
          "name": "Qwen 2.5 Coder 14B",
          "id": "qwen2.5-coder:14b",
          "context_window": 32768,
          "default_max_tokens": 8192
        },
        {
          "name": "Qwen 2.5 Coder 7B",
          "id": "qwen2.5-coder:7b",
          "context_window": 32768,
          "default_max_tokens": 8192
        }
      ]
    },
    "ollama-research": {
      "name": "Local Ollama Research",
      "base_url": "http://localhost:11434/v1/",
      "type": "openai-compat",
      "models": [
        {
          "name": "Llama 3.1 8B",
          "id": "llama3.1:8b",
          "context_window": 131072,
          "default_max_tokens": 8192
        }
      ]
    }
  },
  "agents": {
    "coder": {
      "model": "qwen2.5-coder:14b",
      "maxTokens": 8000,
      "temperature": 0.1
    },
    "research": {
      "model": "llama3.1:8b",
      "maxTokens": 4000,
      "temperature": 0.3
    },
    "task": {
      "model": "qwen2.5-coder:7b",
      "maxTokens": 2000,
      "temperature": 0.2
    },
    "title": {
      "model": "llama3.1:8b",
      "maxTokens": 100,
      "temperature": 0.5
    }
  },
  "lsp": {
    "go": {
      "command": "gopls"
    },
    "typescript": {
      "command": "typescript-language-server",
      "args": ["--stdio"]
    },
    "python": {
      "command": "pylsp"
    },
    "rust": {
      "command": "rust-analyzer"
    },
    "java": {
      "command": "jdtls"
    }
  },
  "options": {
    "debug": false,
    "disable_notifications": false,
    "auto_save": true
  }
}